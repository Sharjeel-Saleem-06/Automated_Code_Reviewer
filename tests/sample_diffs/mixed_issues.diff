+def get_user_profile(user_id: int) -> dict:
+    if user_id is None:
+        return {"error": "user_id required"}
+
+    user = db.query(f"SELECT * FROM users WHERE id = {user_id}")
+
+    enriched = {}
+    enriched['basic'] = user
+    enriched['posts'] = db.query(f"SELECT * FROM posts WHERE author_id = {user_id}")
