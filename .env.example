# ============================================================
# MULTI-AGENT CODE REVIEWER — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# NEVER commit .env to Git. It is listed in .gitignore.

# --- Required: Anthropic API Key ---
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- Optional: GitHub Integration (for real PR reviews) ---
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-personal-access-token

# --- Optional: Pinecone (for RAG knowledge base) ---
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=code-review-knowledge

# --- Optional: LangSmith (for production tracing) ---
LANGSMITH_API_KEY=your-langsmith-key-here
LANGSMITH_PROJECT=multi-agent-code-reviewer
LANGCHAIN_TRACING_V2=false
